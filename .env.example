# Backend env. Copy to .env for local dev.
NODE_ENV=development
PORT=5001

# Postgres (matches docker-compose.yml)
DATABASE_URL=postgresql://nafas:nafas@localhost:5433/nafas

# JWT secrets — change in any non-local environment
JWT_ACCESS_SECRET=dev_access_secret_change_me_min_16_chars
JWT_REFRESH_SECRET=dev_refresh_secret_change_me_min_16_chars
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=30d
