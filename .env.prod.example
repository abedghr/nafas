# Production env for docker-compose.prod.yml. Copy to .env.prod and fill in.

# Public HTTPS URL the app is reached at (baked into the web build).
PUBLIC_URL=https://your-domain.example

# App port on the host (behind your reverse proxy / PaaS).
APP_PORT=5001

# Postgres password (used by both the db service and DATABASE_URL).
DB_PASSWORD=change_me_strong_password

# JWT secrets — generate with:  openssl rand -hex 32
JWT_ACCESS_SECRET=change_me_min_32_hex
JWT_REFRESH_SECRET=change_me_min_32_hex

# OTP email (optional). Without these, signup codes are only printed to logs.
# Any SMTP provider works (Resend, Brevo, Gmail app-password, Mailgun, SES…).
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=Nafas <no-reply@your-domain.example>
